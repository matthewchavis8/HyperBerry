{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/aarch64-toolchain.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/aarch64-toolchain.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "integration-test",
      "displayName": "Integration Tests (bare-metal, TAP)",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/integration-test",
      "cacheVariables": {
        "INTEGRATION_TEST": "ON"
      }
    },
    {
      "name": "unit-tests",
      "displayName": "Unit Tests (aarch64-linux, GTest)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/unit-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/aarch64-linux-toolchain.cmake",
        "BUILD_TESTING": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "integration-test",
      "configurePreset": "integration-test"
    },
    {
      "name": "unit-tests",
      "configurePreset": "unit-tests"
    }
  ],
  "testPresets": [
    {
      "name": "unit-tests",
      "configurePreset": "unit-tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
